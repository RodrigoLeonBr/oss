# Copie para a raiz do projeto:  cp env.docker.example .env
# O docker compose lê o .env para variáveis e o container recebe o que está em `environment` no docker-compose.
# Obrigatório: ajuste JWT_SECRET antes do primeiro up em produção.

NODE_ENV=production
PORT=4001

# MySQL — no Compose o host do serviço é "db" (não use localhost)
DB_HOST=db
DB_PORT=3306
DB_USER=ossuser
DB_PASS=rootpass
DB_NAME=oss

JWT_SECRET=defina-uma-chave-longa-e-aleatoria
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=30

LOG_FOLDER=logs/
LOG_FILE=%DATE%-app-log.log
LOG_LEVEL=error

# Redis — host do serviço é "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USE_PASSWORD=no
REDIS_PASSWORD=
